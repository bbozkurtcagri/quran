<?xml version="1.0" encoding="utf-8"?>
<!--
  Sadece localhost ve 10.0.2.2 (Android emulator → host Mac) için cleartext HTTP'ye izin ver.
  Üretimde HTTPS arkasında olacak; bu yalnızca yerel geliştirme içindir.
  iOS'taki NSAllowsLocalNetworking eşdeğeri.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
    </domain-config>
</network-security-config>
